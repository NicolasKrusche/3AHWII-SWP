{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/openai/gpt-oss-20b:free",
  "small_model": "openrouter/meta-llama/llama-3.2-3b-instruct:free",
  "provider": {
    "openrouter": {
      "name": "OpenRouter Free Tier",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "timeout": 600000
      },
      "models": {
        "openai/gpt-oss-20b:free": {
          "name": "GPT OSS 20B (OpenRouter Free)"
        },
        "meta-llama/llama-3.3-70b-instruct:free": {
          "name": "Llama 3.3 70B Instruct (OpenRouter Free)"
        },
        "google/gemma-3-27b-it:free": {
          "name": "Gemma 3 27B IT (OpenRouter Free)"
        }
      }
    },
    "google": {
      "name": "Google AI Studio / Gemini Free Tier",
      "options": {
        "apiKey": "{env:GOOGLE_API_KEY}",
        "timeout": 600000
      },
      "models": {
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash"
        },
        "gemini-2.5-flash-lite": {
          "name": "Gemini 2.5 Flash Lite"
        },
        "gemma-3-4b-it": {
          "name": "Gemma 3 4B IT"
        }
      }
    },
    "groq": {
      "name": "Groq Free Tier",
      "options": {
        "baseURL": "https://api.groq.com/openai/v1",
        "apiKey": "{env:GROQ_API_KEY}",
        "timeout": 600000
      },
      "models": {
        "openai/gpt-oss-20b": {
          "name": "GPT OSS 20B"
        },
        "llama-3.1-8b-instant": {
          "name": "Llama 3.1 8B Instant"
        },
        "llama-3.3-70b-versatile": {
          "name": "Llama 3.3 70B Versatile"
        }
      }
    },
    "huggingface": {
      "name": "Hugging Face Inference Providers",
      "options": {
        "apiKey": "{env:HUGGINGFACE_API_KEY}",
        "timeout": 600000
      },
      "models": {
        "Qwen/Qwen3-Coder-Next": {
          "name": "Qwen3 Coder Next"
        },
        "moonshotai/Kimi-K2-Instruct": {
          "name": "Kimi K2 Instruct"
        }
      }
    },
    "nvidia": {
      "name": "NVIDIA API Catalog",
      "options": {
        "apiKey": "{env:NVIDIA_API_KEY}",
        "timeout": 600000
      },
      "models": {
        "openai/gpt-oss-20b": {
          "name": "GPT OSS 20B"
        },
        "meta/llama-3.1-70b-instruct": {
          "name": "Llama 3.1 70B Instruct"
        }
      }
    },
    "mistral-free": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mistral API",
      "options": {
        "baseURL": "https://api.mistral.ai/v1",
        "apiKey": "{env:MISTRAL_API_KEY}",
        "timeout": 600000
      },
      "models": {
        "mistral-small-latest": {
          "name": "Mistral Small Latest"
        },
        "codestral-latest": {
          "name": "Codestral Latest"
        }
      }
    },
    "ollama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Local",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "timeout": 600000
      },
      "models": {
        "llama3.2:3b": {
          "name": "Llama 3.2 3B (local)"
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B (local)"
        }
      }
    }
  }
}
